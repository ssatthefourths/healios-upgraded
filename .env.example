# ─────────────────────────────────────────────────────────────────
# Healios — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is committed as documentation.
# ─────────────────────────────────────────────────────────────────

# Cloudflare Worker API URL (frontend → worker)
# For local dev the default points to the production worker, which is fine.
# To run the worker locally: cd worker-api && npx wrangler dev
# Then set: VITE_CF_WORKER_URL=http://localhost:8787
VITE_CF_WORKER_URL=https://healios-api.ss-f01.workers.dev

# Microsoft Clarity — Behavioral analytics & heatmaps (optional)
VITE_CLARITY_ID=vsma9av1yg

# ─────────────────────────────────────────────────────────────────
# Worker secrets — set via wrangler CLI, NOT in this file:
#   cd worker-api
#   npx wrangler secret put STRIPE_KEY
#   npx wrangler secret put STRIPE_WEBHOOK_SECRET
#   npx wrangler secret put RESEND_API_KEY
#   npx wrangler secret put JWT_SECRET
#   npx wrangler secret put LOVABLE_API_KEY
# ─────────────────────────────────────────────────────────────────
